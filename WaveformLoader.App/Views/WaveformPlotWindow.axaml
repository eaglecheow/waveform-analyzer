<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="WaveformLoader.App.Views.WaveformPlotWindow"
        RequestedThemeVariant="Light"
        Background="#E2E8F0"
        Width="1220"
        Height="760"
        MinWidth="900"
        MinHeight="560"
        Title="Waveform Plot">
  <Grid RowDefinitions="Auto,*,Auto" Margin="18" RowSpacing="12">
    <Border Padding="12" Background="#0F172A" CornerRadius="12">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
        <Button Content="Reset"
                Click="ResetButton_OnClick" />
        <Button Grid.Column="1"
                Content="Fit"
                Click="FitButton_OnClick" />
        <Button Grid.Column="2"
                Content="Open Another Waveform"
                Click="OpenAnotherWaveformButton_OnClick" />
        <TextBlock Grid.Column="3"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontWeight="SemiBold"
                   Text="{Binding SeriesSummary}" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="*,340" ColumnSpacing="12">
      <Border Padding="10" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12">
        <scott:AvaPlot x:Name="PlotControl"
                       Tapped="PlotControl_OnTapped" />
      </Border>

      <Border Grid.Column="1" Padding="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Measurements" />
          <TextBlock Grid.Row="1"
                     Foreground="#475569"
                     Text="Selected measurement markers are shown on the plot."
                     TextWrapping="Wrap" />
          <ListBox Grid.Row="2"
                   ItemsSource="{Binding Measurements}"
                   SelectedItem="{Binding SelectedMeasurement}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="10">
                  <StackPanel Spacing="6">
                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Text="{Binding DisplayName}" />
                    <TextBlock FontFamily="Consolas"
                               FontSize="16"
                               Text="{Binding ValueText}" />
                    <TextBlock Foreground="#475569"
                               Text="{Binding DetailText}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <Border Padding="12" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10">
        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </Border>
      <Border Grid.Column="1" Padding="12" Background="#EFF6FF" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="10">
        <TextBlock FontFamily="Consolas"
                   FontSize="14"
                   Text="{Binding SelectedPointText}" />
      </Border>
    </Grid>
  </Grid>
</Window>
